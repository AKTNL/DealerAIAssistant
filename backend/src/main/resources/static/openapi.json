            "type": "integer"
          },
          "wonCount": {
            "type": "integer"
          },
          "lostCount": {
            "type": "integer"
          },
          "openCount": {
            "type": "integer"
          },
          "winRate": {
            "type": "number"
          },
          "stageDistribution": {
            "type": "object",
            "additionalProperties": {
              "type": "integer"
            }
          },
          "topLossReasons": {
