  "paths": {
    "/api/targets/metrics": {
      "get": {
        "operationId": "getTargetMetrics",
        "summary": "【目标达成】指标汇总查询",
        "parameters": [
          {
            "name": "year",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "month",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "productModel",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dealerCode",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "city",
            "in": "query",
            "description": "Optional city filter. Supports values such as 沈阳 or Beijing.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dealerName",
            "in": "query",
            "description": "Optional dealer name keyword filter, such as 经销商AJ.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dealerGroupName",
            "in": "query",
            "description": "Optional dealer group name keyword filter.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer"
                    },
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "$ref": "#/components/schemas/TargetMetrics"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
