          "averageAchievementRate": {
            "type": "number"
          },
          "lowestDealer": {
            "$ref": "#/components/schemas/DealerMetric"
          },
          "highestDealer": {
            "$ref": "#/components/schemas/DealerMetric"
          }
        }
      },
      "DealerMetric": {
        "type": "object",
        "properties": {
          "dealerCode": {
            "type": "string"
          },
          "dealerName": {
            "type": "string"
